{
  "name": "taskforge",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/src/index.js",
    "client:dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node server/src/index.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "concurrently": "8.2.2",
    "cors": "2.8.5",
    "date-fns": "3.6.0",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "framer-motion": "11.18.2",
    "jsonwebtoken": "9.0.2",
    "lucide-react": "0.468.0",
    "mongoose": "8.9.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vite": "5.4.11"
  },
  "devDependencies": {
    "eslint": "9.17.0",
    "globals": "15.14.0",
    "nodemon": "3.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
